{
  "routes": [
    {
      "route": "/api/signup",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/login",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/me",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/chat",
      "allowedRoles": ["anonymous"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  }
}
